# Copy to .env and fill in. Never commit .env.

# Shopify app credentials, from the Partner Dashboard (Apps > your app > Client credentials).
# SHOPIFY_API_SECRET is required: the App Proxy handler uses it to verify request signatures.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public HTTPS URL where THIS app is hosted. Must match `application_url` and the
# [app_proxy] url host in ../shopify.app.toml.
APP_URL=https://your-app-host.example.com

# Stand-in for the per-shop token lookup in this stub. In production you store one token
# per shop (set when the merchant installs / enters it in app settings) and delete this.
# XltJvQpczMk0bDsG is the public demo token.
SCADABLE_TOKEN=XltJvQpczMk0bDsG

# Optional override of the SCADABLE policy serve base.
SCADABLE_API=https://policy.scadable.com

PORT=3000
