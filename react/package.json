{
  "name": "@scadable/react",
  "version": "0.1.0",
  "description": "Render your always-current SCADABLE privacy policy or terms of use in any React app (Vite, CRA, Remix, Gatsby).",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/postbuild-directives.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scadable",
    "privacy",
    "privacy-policy",
    "terms-of-use",
    "compliance",
    "react",
    "vite"
  ],
  "dependencies": {
    "@scadable/core": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scadable/sdk.git",
    "directory": "react"
  }
}
